<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="uav_minimal">
  <xacro:arg name="prefix" default=""/>
  <xacro:arg name="base_frame" default="base_link"/>
  <xacro:property name="prefix" value="$(arg prefix)"/>
  <xacro:property name="base_frame" value="$(arg base_frame)"/>

  <xacro:property name="PI" value="3.1415926535897931"/>
  <xacro:property name="mesh_root" value="package://uav_description/models/uav_base/meshes"/>
  <xacro:property name="rotor_x_offset" value="0.09"/>
  <xacro:property name="rotor_y_offset" value="0.09"/>
  <xacro:property name="rotor_z" value="0.033"/>
  <xacro:property name="motor_base_z" value="0.0325"/>
  <xacro:property name="motor_base_yaw" value="-0.45"/>
  <xacro:property name="propeller_z" value="0.01"/>
  <xacro:property name="base_mass" value="1.19196153846"/>
  <xacro:property name="base_ixx" value="0.002926086497"/>
  <xacro:property name="base_iyy" value="0.002922870097"/>
  <xacro:property name="base_izz" value="0.004866464599"/>
  <xacro:property name="rotor_mass" value="0.002009615385"/>
  <xacro:property name="rotor_ixx" value="0.00000001202"/>
  <xacro:property name="rotor_iyy" value="0.00000081612"/>
  <xacro:property name="rotor_izz" value="0.000000828081"/>

  <material name="uav_dark">
    <color rgba="0.18 0.18 0.18 1.0"/>
  </material>

  <material name="uav_camera">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>

  <material name="uav_optical_lens">
    <color rgba="0.04 0.06 0.08 1.0"/>
  </material>

  <material name="uav_optical_range">
    <color rgba="0.10 0.10 0.10 1.0"/>
  </material>

  <xacro:macro name="uav_motor_base_visual" params="x y">
    <visual>
      <origin xyz="${x} ${y} ${motor_base_z}" rpy="0 0 ${motor_base_yaw}"/>
      <geometry>
        <mesh filename="${mesh_root}/motor_2306_base.dae" scale="0.5 0.5 0.5"/>
      </geometry>
    </visual>
  </xacro:macro>

  <xacro:macro name="uav_rotor" params="index x y">
    <link name="${prefix}rotor_${index}">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${rotor_mass}"/>
        <inertia ixx="${rotor_ixx}" ixy="0.0" ixz="0.0" iyy="${rotor_iyy}" iyz="0.0" izz="${rotor_izz}"/>
      </inertial>

      <visual>
        <origin xyz="0 0 ${propeller_z}" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_root}/propeller_5x3.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="uav_dark"/>
      </visual>

      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_root}/motor_2306_bell.dae" scale="0.5 0.5 0.5"/>
        </geometry>
      </visual>
    </link>

    <joint name="${prefix}rotor_${index}_joint" type="fixed">
      <parent link="${prefix}${base_frame}"/>
      <child link="${prefix}rotor_${index}"/>
      <origin xyz="${x} ${y} ${rotor_z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <link name="${prefix}${base_frame}">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${base_mass}"/>
      <inertia ixx="${base_ixx}" ixy="0.0" ixz="0.0" iyy="${base_iyy}" iyz="0.0" izz="${base_izz}"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_root}/dj250_airframe.dae" scale="1 1 1"/>
      </geometry>
    </visual>

    <xacro:uav_motor_base_visual x="${rotor_x_offset}" y="${-rotor_y_offset}"/>
    <xacro:uav_motor_base_visual x="${-rotor_x_offset}" y="${rotor_y_offset}"/>
    <xacro:uav_motor_base_visual x="${rotor_x_offset}" y="${rotor_y_offset}"/>
    <xacro:uav_motor_base_visual x="${-rotor_x_offset}" y="${-rotor_y_offset}"/>

    <visual>
      <origin xyz="0.005 0 -0.081" rpy="0 0 0"/>
      <geometry>
        <box size="0.030 0.015 0.005"/>
      </geometry>
      <material name="uav_dark"/>
    </visual>

    <visual>
      <origin xyz="0.012 0 -0.0838" rpy="0 0 0"/>
      <geometry>
        <box size="0.008 0.008 0.0008"/>
      </geometry>
      <material name="uav_optical_lens"/>
    </visual>

    <visual>
      <origin xyz="-0.008 0 -0.0838" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.0025" length="0.0008"/>
      </geometry>
      <material name="uav_optical_range"/>
    </visual>
  </link>

  <xacro:uav_rotor index="0" x="${rotor_x_offset}" y="${-rotor_y_offset}"/>
  <xacro:uav_rotor index="1" x="${-rotor_x_offset}" y="${rotor_y_offset}"/>
  <xacro:uav_rotor index="2" x="${rotor_x_offset}" y="${rotor_y_offset}"/>
  <xacro:uav_rotor index="3" x="${-rotor_x_offset}" y="${-rotor_y_offset}"/>

  <link name="${prefix}camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 ${PI / 2.0} 0"/>
      <geometry>
        <box size="0.008 0.018 0.014"/>
      </geometry>
      <material name="uav_camera"/>
    </visual>
  </link>

  <joint name="${prefix}camera_joint" type="fixed">
    <parent link="${prefix}${base_frame}"/>
    <child link="${prefix}camera_link"/>
    <origin xyz="0.0903 0 0.0098" rpy="0 0 0"/>
  </joint>

  <link name="${prefix}camera_optical_frame"/>

  <joint name="${prefix}camera_optical_joint" type="fixed">
    <parent link="${prefix}camera_link"/>
    <child link="${prefix}camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <link name="${prefix}stereo_camera_link">
    <visual>
      <origin xyz="-0.0051 0 -0.0125" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_root}/camera_orbbec_gemini336_link.stl" scale="1 1 1"/>
      </geometry>
      <material name="uav_camera"/>
    </visual>
  </link>

  <joint name="${prefix}stereo_camera_joint" type="fixed">
    <parent link="${prefix}${base_frame}"/>
    <child link="${prefix}stereo_camera_link"/>
    <origin xyz="0.0503 0 0.1043" rpy="0 0 0"/>
  </joint>

  <link name="${prefix}stereo_camera_optical_frame"/>

  <joint name="${prefix}stereo_camera_optical_joint" type="fixed">
    <parent link="${prefix}stereo_camera_link"/>
    <child link="${prefix}stereo_camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>
</robot>
