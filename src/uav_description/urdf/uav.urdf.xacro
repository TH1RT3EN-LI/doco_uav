<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="uav_minimal">
  <xacro:arg name="prefix" default=""/>
  <xacro:arg name="base_frame" default="base_link"/>
  <xacro:property name="prefix" value="$(arg prefix)"/>
  <xacro:property name="base_frame" value="$(arg base_frame)"/>

  <xacro:property name="arm_l" value="0.26"/>
  <xacro:property name="arm_w" value="0.015"/>
  <xacro:property name="arm_h" value="0.015"/>
  <xacro:property name="rotor_r" value="0.055"/>
  <xacro:property name="rotor_h" value="0.008"/>
  <xacro:property name="rotor_z" value="0.03"/>
  <!-- hw_uav.params uses PX4 FRD; base_link here is FLU, so rotor Y is sign-flipped. -->
  <xacro:property name="rotor_x_offset" value="0.09"/>
  <xacro:property name="rotor_y_offset" value="0.09"/>

  <link name="${prefix}${base_frame}">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0.78539816339"/>
      <geometry>
        <box size="${arm_l} ${arm_w} ${arm_h}"/>
      </geometry>
      <material name="uav_arm">
        <color rgba="0.85 0.85 0.85 1.0"/>
      </material>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 2.35619449018"/>
      <geometry>
        <box size="${arm_l} ${arm_w} ${arm_h}"/>
      </geometry>
      <material name="uav_arm"/>
    </visual>
  </link>

  <link name="${prefix}rotor_0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${rotor_r}" length="${rotor_h}"/>
      </geometry>
      <material name="uav_rotor_cw">
        <color rgba="0.1 0.7 1.0 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="${prefix}rotor_0_joint" type="fixed">
    <parent link="${prefix}${base_frame}"/>
    <child link="${prefix}rotor_0"/>
    <origin xyz="${rotor_x_offset} -${rotor_y_offset} ${rotor_z}" rpy="0 0 0"/>
  </joint>

  <link name="${prefix}rotor_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${rotor_r}" length="${rotor_h}"/>
      </geometry>
      <material name="uav_rotor_cw">
        <color rgba="1.0 0.45 0.2 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="${prefix}rotor_1_joint" type="fixed">
    <parent link="${prefix}${base_frame}"/>
    <child link="${prefix}rotor_1"/>
    <origin xyz="-${rotor_x_offset} ${rotor_y_offset} ${rotor_z}" rpy="0 0 0"/>
  </joint>

  <link name="${prefix}rotor_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${rotor_r}" length="${rotor_h}"/>
      </geometry>
      <material name="uav_rotor_ccw"/>
    </visual>
  </link>
  <joint name="${prefix}rotor_2_joint" type="fixed">
    <parent link="${prefix}${base_frame}"/>
    <child link="${prefix}rotor_2"/>
    <origin xyz="${rotor_x_offset} ${rotor_y_offset} ${rotor_z}" rpy="0 0 0"/>
  </joint>

  <link name="${prefix}rotor_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${rotor_r}" length="${rotor_h}"/>
      </geometry>
      <material name="uav_rotor_ccw"/>
    </visual>
  </link>
  <joint name="${prefix}rotor_3_joint" type="fixed">
    <parent link="${prefix}${base_frame}"/>
    <child link="${prefix}rotor_3"/>
    <origin xyz="-${rotor_x_offset} -${rotor_y_offset} ${rotor_z}" rpy="0 0 0"/>
  </joint>

  <!-- Legacy visualization alias for the mono camera. Canonical mono TF is published by launch/profile. -->
  <link name="${prefix}camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
      <material name="uav_camera">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="${prefix}camera_joint" type="fixed">
    <parent link="${prefix}${base_frame}"/>
    <child link="${prefix}camera_link"/>
    <origin xyz="0.05 0 -0.02" rpy="0 0 0"/>
  </joint>

  <link name="${prefix}camera_optical_frame"/>
  <joint name="${prefix}camera_optical_joint" type="fixed">
    <parent link="${prefix}camera_link"/>
    <child link="${prefix}camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <link name="${prefix}stereo_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.0307 0.09 0.025"/>
      </geometry>
      <material name="uav_camera">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="${prefix}stereo_camera_joint" type="fixed">
    <parent link="${prefix}${base_frame}"/>
    <child link="${prefix}stereo_camera_link"/>
    <origin xyz="0.05 0 0.045" rpy="0 0 0"/>
  </joint>

  <link name="${prefix}stereo_camera_optical_frame"/>
  <joint name="${prefix}stereo_camera_optical_joint" type="fixed">
    <parent link="${prefix}stereo_camera_link"/>
    <child link="${prefix}stereo_camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>
</robot>
