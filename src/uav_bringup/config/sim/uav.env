# Default environment for PX4 SITL + Gazebo UAV bringup.
# Keep any value already provided by launch / shell.
PX4_SYS_AUTOSTART=${PX4_SYS_AUTOSTART:-4901}
PX4_SIM_MODEL=${PX4_SIM_MODEL:-gz_uav}
PX4_GZ_WORLD=${PX4_GZ_WORLD:-test}
UAV_PX4_FRAME=${UAV_PX4_FRAME:-sim_uav}
UAV_PX4_FORCE_LOCAL_PARAMS=${UAV_PX4_FORCE_LOCAL_PARAMS:-1}
HEADLESS=${HEADLESS:-0}
